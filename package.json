{
  "name": "hermes-mobile",
  "version": "1.0.0",
  "private": false,
  "description": "Mobile-first Hermes client bridge over the local Hermes API server.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pentiumxp/hermes-mobile-public.git"
  },
  "bugs": {
    "url": "https://github.com/pentiumxp/hermes-mobile-public/issues"
  },
  "homepage": "https://github.com/pentiumxp/hermes-mobile-public#readme",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "check": "node scripts/run-checks.js --check",
