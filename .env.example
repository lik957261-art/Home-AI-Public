# Hermes Mobile listener
HERMES_WEB_HOST=0.0.0.0
HERMES_WEB_PORT=8797
HERMES_WEB_DATA_DIR=workspace/hermes-web
# Defaults to <HERMES_WEB_DATA_DIR>/drive so fresh installs do not create user files in the source checkout.
# HERMES_WEB_OWNER_DEFAULT_WORKSPACE=
# HERMES_WEB_REPO_ROOT=
# HERMES_WEB_CONFIG_DIR=config

# Web login/auth.
# Prefer a secret file or deployment secret manager for real installs.
# HERMES_WEB_KEY=
# HERMES_WEB_AUTH_KEY_PATH=.hermes_web_secret_key
# HERMES_WEB_ALLOW_MEMORY_KEY=0
# HERMES_WEB_DISABLE_AUTH=1

# Hermes Gateway bridge.
HERMES_WEB_HERMES_API_BASE=http://127.0.0.1:8642
# HERMES_WEB_HERMES_API_KEY=
# HERMES_WEB_HERMES_API_KEY_PATH=
# HERMES_WEB_HERMES_ENV_PATH=
HERMES_WEB_HERMES_API_TIMEOUT_MS=8000
# Optional Gateway Pool. "auto" uses the pool only when the manifest exists and
# has enabled workers; the configured Gateway above remains the fallback.
HERMES_WEB_GATEWAY_POOL_ENABLED=auto
# HERMES_WEB_GATEWAY_POOL_MANIFEST=
HERMES_WEB_GATEWAY_POOL_HEALTH_TIMEOUT_MS=5000
# auto preserves legacy manifests; on requires worker skillWorkspaceIds/skillProfile
# routing for ordinary chat/task runs; off disables Skill profile routing hints.
HERMES_MOBILE_GATEWAY_SKILL_PROFILE_ROUTING=auto
# Optional read-only fallback for official Hermes session usage. When Gateway
# responses omit cached-token/cost fields, Hermes Mobile can read profile
# state.db/response_store.db summaries without modifying Gateway source.
# HERMES_MOBILE_GATEWAY_USAGE_TELEMETRY_ENABLED=auto
# Comma-separated read-only roots containing <profile>/state.db and
# <profile>/response_store.db. For isolated workers, prefer explicit
# telemetryStateDbPath / telemetryResponseStoreDbPath fields in the worker
# manifest.
# HERMES_MOBILE_GATEWAY_TELEMETRY_PROFILES_ROOTS=
# User chat/task runs require a healthy manifest worker with securityLevel=user.
# Owner-maintenance workers are never used for ordinary runs.
# HERMES_MOBILE_ALLOW_OWNER_MAINTENANCE_RUNS=0
# 0 disables the corresponding limit. In pooled production, set both explicitly.
HERMES_WEB_MAX_ACTIVE_RUNS=0
HERMES_WEB_MAX_ACTIVE_RUNS_PER_WORKSPACE=0

# Optional Weixin ingress sidecar boundary. Configure this only when Hermes
# Mobile owns Weixin/iLink polling for an account; do not run two pollers for
# the same Weixin account.
# HERMES_MOBILE_WEIXIN_INGRESS_KEY=
# HERMES_MOBILE_WEIXIN_INGRESS_KEY_PATH=workspace/hermes-web/weixin-ingress.secret
# HERMES_MOBILE_WEIXIN_INGRESS_DEFAULT_WORKSPACE=

# Optional local integration paths.
# These must be deployment-specific and must not be committed with secrets.
# HERMES_WEB_WORKSPACE_USERS_PATH=
# HERMES_WEB_WORKSPACE_ROUTE_MAP_PATH=
# HERMES_WEB_ENABLE_LEGACY_WEIXIN_COMPAT=0
# HERMES_WEB_PRINCIPAL_LABEL_PREFIXES=
# HERMES_WEB_PROJECT_MAP_PATH=
# HERMES_WEB_OWNER_LABEL=Owner
# HERMES_WEB_OWNER_ALIASES=owner
# HERMES_WEB_OWNER_ROOT_LABEL=Hermes Owner
# HERMES_WEB_OWNER_DRIVE_ROOT_NAMES=ChatGPT-Drive
# HERMES_WEB_GENERIC_OWNER_PROJECT_PREFIXES=owner-
# HERMES_WEB_GENERIC_OWNER_PROJECT_IDS=hermes-sync-folder
# HERMES_WEB_CRON_JOBS_PATH=
# HERMES_WEB_CRON_OUTPUT_ROOT=
# HERMES_WEB_RUN_LOG_ROOT=
# Defaults to local JSON stores under HERMES_WEB_DATA_DIR for product installs.
# Set these to bridge/hermes_todos or bridge/hermes_cron only when intentionally connecting to a deployment-owned plugin/CRON store.
# HERMES_WEB_TODO_BACKEND=local
# HERMES_WEB_TODO_STORE_PATH=
# HERMES_WEB_AUTOMATION_BACKEND=local
# HERMES_WEB_AUTOMATION_STORE_PATH=
# Optional SQLite service store for local Todo/Automation and migration work.
# HERMES_WEB_SERVICE_STORE=sqlite
# HERMES_WEB_DB_PATH=workspace/hermes-web/hermes-mobile.sqlite3
# HERMES_WEB_ALLOWED_ARTIFACT_ROOTS=
# Security boundary. Defaults protect source, config, secret, token, DB, and
# Hermes-home paths while allowing narrow user-data/artifact roots.
# HERMES_MOBILE_SECURITY_PROTECTED_ROOTS=
# HERMES_MOBILE_SECURITY_PROTECTED_FILES=
# HERMES_MOBILE_SECURITY_ALLOWED_EXCEPTIONS=
# Do not enable these bypasses in production.
# HERMES_MOBILE_SECURITY_ALLOW_UNRESTRICTED=0
# HERMES_MOBILE_SECURITY_ALLOW_DEVELOPER_TOOLSETS=0
# HERMES_WEB_WSL_DISTRO=
# HERMES_WEB_WSL_USER=
# HERMES_WEB_WSL_HOME=
# HERMES_WEB_WSL_HERMES_HOME=
# HERMES_WEB_HERMES_HOME=
# HERMES_WEB_HERMES_REPO=
# HERMES_WEB_TODO_PLUGIN_PATH=
# HERMES_WEB_TODO_PLUGIN_NAME=hermes_todos
# HERMES_WEB_SKILLS_ROOT=
# Optional external bridge scripts. Defaults use the repository stub scripts.
# These may be Windows paths, WSL absolute paths, or \\wsl.localhost\...\ paths on Windows.
# HERMES_WEB_TODO_BRIDGE_SCRIPT=
# HERMES_WEB_CRON_BRIDGE_SCRIPT=
# HERMES_WEB_DIRECTORY_BRIDGE_SCRIPT=
# HERMES_WEB_SKILL_BRIDGE_SCRIPT=
# HERMES_WEB_DISABLED_VOLUME1_WINDOWS_MIRROR_SHARES=
# HERMES_WEB_WORKSPACE_INTERFACE_TOOLSETS_JSON={}

# Web Push.
# HERMES_WEB_PUSH_SUBJECT=mailto:hermes-mobile@example.invalid
# HERMES_WEB_VAPID_PATH=workspace/hermes-web/web-push-vapid.json
# WEB_PUSH_VAPID_PUBLIC_KEY=
# WEB_PUSH_VAPID_PRIVATE_KEY=

# Runtime behavior.
HERMES_WEB_CHAT_CONTEXT_MAX_MESSAGES=16
HERMES_WEB_CHAT_CONTEXT_MAX_CHARS=20000
HERMES_WEB_RUN_START_TIMEOUT_MS=90000
HERMES_WEB_RUN_LIVENESS_CHECK_AFTER_MS=120000
