# Hermes Web listener
HERMES_WEB_HOST=0.0.0.0
HERMES_WEB_PORT=8797
HERMES_WEB_DATA_DIR=workspace/hermes-web
# HERMES_WEB_REPO_ROOT=
# HERMES_WEB_CONFIG_DIR=config

# Web login/auth.
# Prefer a secret file or deployment secret manager for real installs.
# HERMES_WEB_KEY=
# HERMES_WEB_AUTH_KEY_PATH=.hermes_web_secret_key
# HERMES_WEB_ALLOW_MEMORY_KEY=0
# HERMES_WEB_DISABLE_AUTH=1

# Hermes Gateway bridge.
HERMES_WEB_HERMES_API_BASE=http://127.0.0.1:8642
# HERMES_WEB_HERMES_API_KEY=
# HERMES_WEB_HERMES_API_KEY_PATH=
# HERMES_WEB_HERMES_ENV_PATH=
HERMES_WEB_HERMES_API_TIMEOUT_MS=8000

# Optional local integration paths.
# These must be deployment-specific and must not be committed with secrets.
# HERMES_WEB_PROJECT_MAP_PATH=
# HERMES_WEB_OWNER_ALIASES=owner
# HERMES_WEB_OWNER_ROOT_LABEL=Hermes Owner
# HERMES_WEB_GENERIC_OWNER_PROJECT_PREFIXES=owner-
# HERMES_WEB_GENERIC_OWNER_PROJECT_IDS=hermes-sync-folder
# HERMES_WEB_CRON_JOBS_PATH=
# HERMES_WEB_CRON_OUTPUT_ROOT=
# HERMES_WEB_RUN_LOG_ROOT=
# HERMES_WEB_ALLOWED_ARTIFACT_ROOTS=
# HERMES_WEB_WSL_DISTRO=
# HERMES_WEB_WSL_USER=
# HERMES_WEB_WSL_HOME=
# HERMES_WEB_WSL_HERMES_HOME=
# HERMES_WEB_HERMES_HOME=
# HERMES_WEB_HERMES_REPO=
# HERMES_WEB_TODO_PLUGIN_PATH=
# HERMES_WEB_TODO_PLUGIN_NAME=hermes_todos
# HERMES_WEB_SKILLS_ROOT=
# HERMES_WEB_VOLUME1_MOUNT_HELPERS_JSON={}
# HERMES_WEB_DISABLED_VOLUME1_WINDOWS_MIRROR_SHARES=
# HERMES_WEB_WORKSPACE_INTERFACE_TOOLSETS_JSON={}

# Web Push.
# HERMES_WEB_PUSH_SUBJECT=mailto:hermes-mobile@example.invalid
# HERMES_WEB_VAPID_PATH=workspace/hermes-web/web-push-vapid.json
# WEB_PUSH_VAPID_PUBLIC_KEY=
# WEB_PUSH_VAPID_PRIVATE_KEY=

# Runtime behavior.
HERMES_WEB_CHAT_CONTEXT_MAX_MESSAGES=16
HERMES_WEB_CHAT_CONTEXT_MAX_CHARS=20000
HERMES_WEB_RUN_START_TIMEOUT_MS=90000
HERMES_WEB_RUN_LIVENESS_CHECK_AFTER_MS=120000
